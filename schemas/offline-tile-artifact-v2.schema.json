{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/offline-tile-artifact-v2.schema.json",
  "title": "LandformCraft Offline Tile Artifact v2",
  "description": "Strict, version-frozen v2 contract for the Offline Tile Artifact v2. Rejects unknown fields, versions and encodings instead of falling back.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tileArtifactVersion", "tileId", "sourceBlueprintChecksum", "xIndex", "zIndex",
    "originX", "originZ", "width", "length", "minY", "maxY", "coordinateSpace",
    "blockOrder", "minecraftVersion", "dataVersion", "schematicVersion", "schematicPath",
    "blockCount", "paletteSize", "byteLength", "artifactChecksum", "semanticChecksum",
    "canonicalChecksum"
  ],
  "properties": {
    "tileArtifactVersion": { "const": 1 },
    "tileId": { "$ref": "#/$defs/id" },
    "sourceBlueprintChecksum": { "$ref": "#/$defs/checksum" },
    "xIndex": { "type": "integer", "minimum": 0 },
    "zIndex": { "type": "integer", "minimum": 0 },
    "originX": { "type": "integer", "minimum": 0, "maximum": 999 },
    "originZ": { "type": "integer", "minimum": 0, "maximum": 999 },
    "width": { "type": "integer", "minimum": 1, "maximum": 256 },
    "length": { "type": "integer", "minimum": 1, "maximum": 256 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "coordinateSpace": { "const": "RELEASE_LOCAL_XYZ" },
    "blockOrder": { "const": "SPONGE_X_Z_Y_V1" },
    "minecraftVersion": { "const": "1.21.11" },
    "dataVersion": { "const": 4671 },
    "schematicVersion": { "const": 3 },
    "schematicPath": {
      "type": "string",
      "minLength": 7,
      "maxLength": 512,
      "pattern": "^(?:[a-z0-9][a-z0-9._-]{0,63}/)*[a-z0-9][a-z0-9._-]{0,63}\\.schem$"
    },
    "blockCount": { "type": "integer", "minimum": 1, "maximum": 33554432 },
    "paletteSize": { "type": "integer", "minimum": 1, "maximum": 16384 },
    "byteLength": { "type": "integer", "minimum": 1, "maximum": 67108864 },
    "artifactChecksum": { "$ref": "#/$defs/checksum" },
    "semanticChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
