{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/ice-fjord-plan-v2.schema.json",
  "title": "LandformCraft V2-10-01 ICE_FJORD composite preset plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-01 ICE_FJORD composite preset plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "presetId", "contractVersion", "fjordFeatureId", "fjordGeometryChecksum",
    "valleyGlacierFeatureId", "valleyGlacierPlanChecksum", "climatePreset",
    "climateBindingChecksum", "snowProfileId", "supportRadiusXZ", "estimatedWorkUnits",
    "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "presetId": { "$ref": "#/$defs/slug" },
    "contractVersion": { "const": "ice-fjord-preset-contract-v1" },
    "fjordFeatureId": { "$ref": "#/$defs/slug" },
    "fjordGeometryChecksum": { "$ref": "#/$defs/checksum" },
    "valleyGlacierFeatureId": { "$ref": "#/$defs/slug" },
    "valleyGlacierPlanChecksum": { "$ref": "#/$defs/checksum" },
    "climatePreset": { "enum": ["COLD_ALPINE", "COLD_MARITIME", "COOL_HIGH_ALTITUDE"] },
    "climateBindingChecksum": { "$ref": "#/$defs/checksum" },
    "snowProfileId": { "const": "cold-snow-ice-profile" },
    "supportRadiusXZ": { "type": "integer", "minimum": 2, "maximum": 64 },
    "estimatedWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
