{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/volume-csg-plan-v2.schema.json",
  "title": "LandformCraft V2-5-02 ordered VolumePlan CSG contract",
  "description": "Strict, version-frozen v2 contract for the V2-5-02 ordered VolumePlan CSG contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "csgContractVersion", "primitivePlanBinding", "kernel",
    "operators", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": {"const": 1},
    "csgContractVersion": {"const": "volume-csg-contract-v1"},
    "primitivePlanBinding": {"$ref": "#/$defs/primitivePlanBinding"},
    "kernel": {"$ref": "#/$defs/kernel"},
    "operators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/operator"}
    },
    "budget": {"$ref": "#/$defs/budget"},
    "canonicalChecksum": {"$ref": "#/$defs/checksum"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "qualified": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "primitivePlanBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingVersion", "sourceVolumeSdfPrimitivePlanChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": {"const": 1},
        "sourceVolumeSdfPrimitivePlanChecksum": {"$ref": "#/$defs/checksum"},
        "bindingContractVersion": {"const": "volume-csg-primitive-binding-v1"}
      }
    },
    "kernel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kernelVersion", "maximumOperators", "maximumDependencyDepth", "maximumCpuWorkUnits"],
      "properties": {
        "kernelVersion": {"const": "volume-csg-ordered-v1"},
        "maximumOperators": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumDependencyDepth": {"type": "integer", "minimum": 1, "maximum": 8},
        "maximumCpuWorkUnits": {"type": "integer", "minimum": 1, "maximum": 1048576}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budgetVersion", "maximumOperators", "maximumDependencyDepth",
        "estimatedCpuWorkUnits", "maximumCpuWorkUnits",
        "estimatedCanonicalBytes", "maximumCanonicalBytes", "maximumWorkingBytes"
      ],
      "properties": {
        "budgetVersion": {"const": "volume-csg-budget-v1"},
        "maximumOperators": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumDependencyDepth": {"type": "integer", "minimum": 1, "maximum": 8},
        "estimatedCpuWorkUnits": {"type": "integer", "minimum": 1},
        "maximumCpuWorkUnits": {"type": "integer", "minimum": 1, "maximum": 1048576},
        "estimatedCanonicalBytes": {"type": "integer", "minimum": 1},
        "maximumCanonicalBytes": {"type": "integer", "minimum": 1, "maximum": 65536},
        "maximumWorkingBytes": {"type": "integer", "minimum": 1}
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operatorId", "ordinal", "kind", "primitiveId", "mask",
        "maskPrimitiveId", "dependsOnOperatorIds", "fluidBodyId"
      ],
      "properties": {
        "operatorId": {"$ref": "#/$defs/qualified"},
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 63},
        "kind": {"enum": ["ADD_SOLID", "CARVE_SOLID", "ADD_FLUID"]},
        "primitiveId": {"$ref": "#/$defs/qualified"},
        "mask": {"enum": ["NONE", "INTERSECTION_WITH_PRIMITIVE"]},
        "maskPrimitiveId": {"type": "string", "maxLength": 128},
        "dependsOnOperatorIds": {
          "type": "array",
          "maxItems": 8,
          "items": {"$ref": "#/$defs/qualified"},
          "uniqueItems": true
        },
        "fluidBodyId": {"type": "string", "maxLength": 128}
      },
      "allOf": [
        {
          "if": {"properties": {"mask": {"const": "NONE"}}, "required": ["mask"]},
          "then": {"properties": {"maskPrimitiveId": {"const": ""}}}
        },
        {
          "if": {"properties": {"mask": {"const": "INTERSECTION_WITH_PRIMITIVE"}}, "required": ["mask"]},
          "then": {"properties": {"maskPrimitiveId": {"$ref": "#/$defs/qualified"}}}
        },
        {
          "if": {"properties": {"kind": {"const": "ADD_FLUID"}}, "required": ["kind"]},
          "then": {"properties": {"fluidBodyId": {"$ref": "#/$defs/qualified"}}}
        },
        {
          "if": {"properties": {"kind": {"enum": ["ADD_SOLID", "CARVE_SOLID"]}}, "required": ["kind"]},
          "then": {"properties": {"fluidBodyId": {"const": ""}}}
        }
      ]
    }
  }
}
