{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/plateau-plan-v2.schema.json",
  "title": "LandformCraft V2-10-06 plateau foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-06 plateau foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "rings", "selectedCapElevationBlocks", "selectedCapReliefBlocks",
    "plateauProfile", "escarpmentTransitionBandBlocks", "minY", "maxY", "width", "length",
    "capMaskFieldId", "ownershipFieldId", "elevationFieldId", "materialHandoffFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "rings": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/ring" } },
    "selectedCapElevationBlocks": { "type": "integer", "minimum": 8, "maximum": 96 },
    "selectedCapReliefBlocks": { "type": "integer", "minimum": 0, "maximum": 8 },
    "plateauProfile": { "enum": ["MESA", "BUTTE", "GENERIC"] },
    "escarpmentTransitionBandBlocks": { "type": "integer", "minimum": 2, "maximum": 32 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "width": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "capMaskFieldId": { "const": "foundation.plateau.cap-mask" },
    "ownershipFieldId": { "const": "foundation.plateau.ownership" },
    "elevationFieldId": { "const": "foundation.plateau.elevation" },
    "materialHandoffFieldId": { "const": "foundation.plateau.material-handoff" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vertex": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 }
      }
    },
    "ring": {
      "type": "object", "additionalProperties": false,
      "required": ["vertices"],
      "properties": {
        "vertices": {
          "type": "array", "minItems": 4, "maxItems": 2048,
          "items": { "$ref": "#/$defs/vertex" }
        }
      }
    }
  }
}
