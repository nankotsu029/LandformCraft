{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/valley-plan-v2.schema.json",
  "title": "LandformCraft V2-9-03 valley foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-9-03 valley foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "thalwegPoints", "crossSection",
    "selectedFloorHalfWidthBlocks", "selectedShoulderWidthBlocks", "selectedMaxDepthBlocks",
    "mountainTransitionBandBlocks", "connectionRole", "connectionAnchors",
    "minY", "maxY", "waterLevel", "width", "length",
    "floorMaskFieldId", "shoulderMaskFieldId", "depthFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "thalwegPoints": { "type": "array", "minItems": 2, "maxItems": 16384, "items": { "$ref": "#/$defs/thalwegPoint" } },
    "crossSection": { "enum": ["V_PROFILE", "U_PROFILE"] },
    "selectedFloorHalfWidthBlocks": { "type": "integer", "minimum": 2, "maximum": 64 },
    "selectedShoulderWidthBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
    "selectedMaxDepthBlocks": { "type": "integer", "minimum": 4, "maximum": 64 },
    "mountainTransitionBandBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
    "connectionRole": { "enum": ["NONE", "FJORD_HEAD", "RIVER_CORRIDOR"] },
    "connectionAnchors": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/connectionAnchor" } },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "waterLevel": { "type": "integer" },
    "width": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "floorMaskFieldId": { "const": "foundation.valley.floor-mask" },
    "shoulderMaskFieldId": { "const": "foundation.valley.shoulder-mask" },
    "depthFieldId": { "const": "foundation.valley.depth" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 64000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "thalwegPoint": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths", "arcLengthMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "arcLengthMillionths": { "type": "integer", "minimum": 0 }
      }
    },
    "connectionAnchor": {
      "type": "object", "additionalProperties": false,
      "required": ["anchorId", "role", "xMillionths", "zMillionths"],
      "properties": {
        "anchorId": { "$ref": "#/$defs/slug" },
        "role": { "enum": ["FJORD_HEAD", "RIVER_CORRIDOR"] },
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
