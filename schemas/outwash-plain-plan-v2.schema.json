{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/outwash-plain-plan-v2.schema.json",
  "title": "LandformCraft V2-10-02 outwash-plain foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-02 outwash-plain foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "glacialParentFeatureId", "glacialParentCanonicalChecksum",
    "glacialParentRelationId", "meltwaterHandoffFeatureId", "meltwaterHandoffChecksum",
    "selectedSedimentThicknessBlocks", "selectedChannelSpacingBlocks", "flowAzimuthDegrees",
    "rings", "width", "length", "minY", "maxY",
    "sedimentOwnershipFieldId", "flowDirectionFieldId", "meltwaterMaskFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "glacialParentFeatureId": { "$ref": "#/$defs/slug" },
    "glacialParentCanonicalChecksum": { "$ref": "#/$defs/checksum" },
    "glacialParentRelationId": { "$ref": "#/$defs/slug" },
    "meltwaterHandoffFeatureId": { "type": "string", "maxLength": 64 },
    "meltwaterHandoffChecksum": { "type": "string", "maxLength": 64 },
    "selectedSedimentThicknessBlocks": { "type": "integer", "minimum": 1, "maximum": 16 },
    "selectedChannelSpacingBlocks": { "type": "integer", "minimum": 2, "maximum": 64 },
    "flowAzimuthDegrees": { "type": "integer", "minimum": 0, "maximum": 359 },
    "rings": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/ring" } },
    "width": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "sedimentOwnershipFieldId": { "const": "foundation.outwash-plain.sediment-ownership" },
    "flowDirectionFieldId": { "const": "foundation.outwash-plain.flow-direction" },
    "meltwaterMaskFieldId": { "const": "foundation.outwash-plain.meltwater-mask" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vertex": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 }
      }
    },
    "ring": {
      "type": "object", "additionalProperties": false,
      "required": ["vertices"],
      "properties": {
        "vertices": {
          "type": "array", "minItems": 4, "maxItems": 2048,
          "items": { "$ref": "#/$defs/vertex" }
        }
      }
    }
  }
}
