{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v1/snapshot-cleanup-plan.schema.json",
  "title": "LandformCraft Snapshot Cleanup Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "planId", "actor", "createdAt", "expiresAt", "retentionDays",
    "entries", "confirmationHash", "executed"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planId": { "type": "string", "format": "uuid" },
    "actor": {
      "type": "object", "additionalProperties": false, "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["PLAYER", "CONSOLE", "SYSTEM"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "retentionDays": { "type": "integer", "minimum": 1, "maximum": 36500 },
    "entries": {
      "type": "array", "maxItems": 4096,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["placementId", "placementState", "journalUpdatedAt", "files"],
        "properties": {
          "placementId": { "type": "string", "format": "uuid" },
          "placementState": { "enum": ["APPLIED", "ROLLED_BACK", "UNDONE"] },
          "journalUpdatedAt": { "type": "string", "format": "date-time" },
          "files": {
            "type": "array", "minItems": 1, "maxItems": 1024,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["relativePath", "checksum", "bytes"],
              "properties": {
                "relativePath": {
                  "type": "string",
                  "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//).+$"
                },
                "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "bytes": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "confirmationHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "executed": { "type": "boolean" }
  }
}
