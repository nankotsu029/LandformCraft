{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/dry-land-modifier-contract-v2.schema.json",
  "title": "LandformCraft V2-10-06 dry-land modifier contract",
  "description": "Strict, version-frozen v2 contract for the V2-10-06 dry-land modifier contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "decisionId", "modifiers",
    "compatibilityNotes", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "dry-land-modifier-contract-v1" },
    "decisionId": { "const": "v2-10-06-dry-land-modifiers" },
    "modifiers": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/modifier" }
    },
    "compatibilityNotes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "modifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "disposition", "hostHint", "rationale"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "DUNE", "COASTAL_DUNE_FIELD", "INLAND_DUNE_FIELD", "BADLANDS",
            "SALT_FLAT", "DESERT_FLAT", "DRY_CANYON"
          ]
        },
        "disposition": { "const": "MODIFIER_OR_FIELD" },
        "hostHint": { "enum": ["PLAIN", "PLATEAU", "HOST"] },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
