{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/glacial-ice-plan-v2.schema.json",
  "title": "LandformCraft V2-10-01 glacial-ice foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-01 glacial-ice foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "iceKind", "bedHostFeatureId", "bedHostKind", "bedHostRelationId",
    "bedHostGeometryChecksum", "climatePreset", "climateBindingChecksum", "snowProfileId",
    "flowAzimuthDegrees", "selectedThicknessBlocks", "selectedHalfWidthBlocks",
    "headXMillionths", "headZMillionths", "terminusXMillionths", "terminusZMillionths",
    "meltwaterHandoffFeatureId", "meltwaterHandoffChecksum", "aabb", "orderedOps",
    "sdfPlanBinding", "csgPlanBinding",
    "surfaceOwnershipFieldId", "volumeOwnershipFieldId", "thicknessFieldId",
    "flowDirectionFieldId", "bedContactFieldId", "meltwaterMaskFieldId",
    "supportRadiusXZ", "estimatedWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "iceKind": { "enum": ["VALLEY_GLACIER", "ICE_CAP", "ICE_SHEET"] },
    "bedHostFeatureId": { "$ref": "#/$defs/slug" },
    "bedHostKind": { "enum": ["VALLEY", "MOUNTAIN_RANGE", "PLAIN"] },
    "bedHostRelationId": { "$ref": "#/$defs/slug" },
    "bedHostGeometryChecksum": { "$ref": "#/$defs/checksum" },
    "climatePreset": { "enum": ["COLD_ALPINE", "COLD_MARITIME", "COOL_HIGH_ALTITUDE"] },
    "climateBindingChecksum": { "$ref": "#/$defs/checksum" },
    "snowProfileId": { "const": "cold-snow-ice-profile" },
    "flowAzimuthDegrees": { "type": "integer", "minimum": 0, "maximum": 359 },
    "selectedThicknessBlocks": { "type": "integer", "minimum": 2, "maximum": 64 },
    "selectedHalfWidthBlocks": { "type": "integer", "minimum": 2, "maximum": 128 },
    "headXMillionths": { "type": "integer" },
    "headZMillionths": { "type": "integer" },
    "terminusXMillionths": { "type": "integer" },
    "terminusZMillionths": { "type": "integer" },
    "meltwaterHandoffFeatureId": { "type": "string", "maxLength": 64 },
    "meltwaterHandoffChecksum": { "type": "string", "maxLength": 64 },
    "aabb": { "$ref": "#/$defs/aabb" },
    "orderedOps": {
      "type": "array", "minItems": 1, "maxItems": 8,
      "items": { "$ref": "#/$defs/orderedVolumeOp" }
    },
    "sdfPlanBinding": { "$ref": "#/$defs/sdfBinding" },
    "csgPlanBinding": { "$ref": "#/$defs/csgBinding" },
    "surfaceOwnershipFieldId": { "const": "foundation.glacial-ice.surface-ownership" },
    "volumeOwnershipFieldId": { "const": "foundation.glacial-ice.volume-ownership" },
    "thicknessFieldId": { "const": "foundation.glacial-ice.thickness" },
    "flowDirectionFieldId": { "const": "foundation.glacial-ice.flow-direction" },
    "bedContactFieldId": { "const": "foundation.glacial-ice.bed-contact" },
    "meltwaterMaskFieldId": { "const": "foundation.glacial-ice.meltwater-mask" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "aabb": {
      "type": "object", "additionalProperties": false,
      "required": [
        "minXMillionths", "minYMillionths", "minZMillionths",
        "maxXMillionths", "maxYMillionths", "maxZMillionths"
      ],
      "properties": {
        "minXMillionths": { "type": "integer" },
        "minYMillionths": { "type": "integer" },
        "minZMillionths": { "type": "integer" },
        "maxXMillionths": { "type": "integer" },
        "maxYMillionths": { "type": "integer" },
        "maxZMillionths": { "type": "integer" }
      }
    },
    "orderedVolumeOp": {
      "type": "object", "additionalProperties": false,
      "required": ["opId", "ordinal", "operationKind", "primitiveId"],
      "properties": {
        "opId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
        "ordinal": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "operationKind": { "const": "ADD_SOLID" },
        "primitiveId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" }
      }
    },
    "sdfBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["bindingVersion", "sourceArtifactChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": { "const": 1 },
        "sourceArtifactChecksum": { "$ref": "#/$defs/checksum" },
        "bindingContractVersion": { "const": "glacial-ice-sdf-binding-v1" }
      }
    },
    "csgBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["bindingVersion", "sourceArtifactChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": { "const": 1 },
        "sourceArtifactChecksum": { "$ref": "#/$defs/checksum" },
        "bindingContractVersion": { "const": "glacial-ice-csg-binding-v1" }
      }
    }
  }
}
