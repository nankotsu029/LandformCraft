{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/coastal-preview-index-v2.schema.json",
  "title": "LandformCraft V2 coastal diagnostic preview index",
  "description": "Strict, version-frozen v2 contract for the V2 coastal diagnostic preview index. Diagnostic preview index that locates generated PNG layers; not a generation input.",
  "type": "object",
  "additionalProperties": false,
  "required": ["previewIndexVersion", "sourceBlueprintChecksum", "width", "length", "layers", "canonicalChecksum"],
  "properties": {
    "previewIndexVersion": {"const": 1},
    "sourceBlueprintChecksum": {"$ref": "#/$defs/checksum"},
    "width": {"type": "integer", "minimum": 1, "maximum": 1000},
    "length": {"type": "integer", "minimum": 1, "maximum": 1000},
    "layers": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"$ref": "#/$defs/layer"}},
    "canonicalChecksum": {"$ref": "#/$defs/checksum"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "layerId": {"enum": ["BEACH_OVERLAY", "HARBOR_OVERLAY", "BREAKWATER_OVERLAY", "CAPE_OVERLAY", "DESIRED_LAND_WATER", "ACTUAL_LAND_WATER", "RESIDUAL_LAND_WATER", "DESIRED_HEIGHT", "ACTUAL_HEIGHT", "RESIDUAL_HEIGHT", "CONSTRAINT_ERRORS"]},
    "layer": {
      "type": "object", "additionalProperties": false,
      "required": ["layerId", "layerVersion", "path", "semantic", "sha256", "byteLength", "width", "length", "paletteId"],
      "properties": {
        "layerId": {"$ref": "#/$defs/layerId"}, "layerVersion": {"const": 1},
        "path": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}\\.png$"},
        "semantic": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
        "sha256": {"$ref": "#/$defs/checksum"}, "byteLength": {"type": "integer", "minimum": 1, "maximum": 8388608},
        "width": {"type": "integer", "minimum": 1, "maximum": 1000},
        "length": {"type": "integer", "minimum": 1, "maximum": 1000},
        "paletteId": {"const": "coastal-diagnostic-palette-v1"}
      }
    }
  }
}
