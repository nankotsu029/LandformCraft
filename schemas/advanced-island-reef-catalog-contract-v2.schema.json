{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/advanced-island-reef-catalog-contract-v2.schema.json",
  "title": "LandformCraft V2-10-08 advanced island/reef catalog contract",
  "description": "Strict, version-frozen v2 contract for the V2-10-08 advanced island/reef catalog contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "decisionId", "selectedCompositionPresets",
    "candidates", "compatibilityNotes", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "advanced-island-reef-catalog-contract-v1" },
    "decisionId": { "const": "v2-10-08-advanced-island-reef-catalog" },
    "selectedCompositionPresets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "string", "enum": ["ATOLL", "BARRIER_ISLAND"] }
    },
    "candidates": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "compatibilityNotes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "disposition", "rationale"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "CORAL_COAST", "MANGROVE_COAST", "VOLCANIC_COAST", "FLOATING_REEF", "DUNE_BACKED_BEACH"
          ]
        },
        "disposition": { "enum": ["COMPOSITE_PRESET_ONLY", "DEFERRED"] },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
