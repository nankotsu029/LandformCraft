{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v1/custom-asset-metadata.schema.json",
  "title": "LandformCraft Custom Asset Metadata",
  "description": "Strict, frozen v1 contract for the Custom Asset Metadata. Rejects unknown fields, versions and encodings instead of falling back.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assetId", "type", "minecraftVersion", "anchorX", "anchorY", "anchorZ", "allowedRotations", "placementKind", "maximumSlope", "waterAllowed"],
  "properties": {
    "schemaVersion": {"const": 1},
    "assetId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "type": {"enum": ["SMALL_PIER", "SMALL_BRIDGE", "FISHING_HUT", "STONE_RUIN", "PATH", "RETAINING_WALL", "STONE_STEPS", "FENCE"]},
    "minecraftVersion": {"const": "1.21.11"},
    "anchorX": {"type": "integer", "minimum": 0, "maximum": 63},
    "anchorY": {"type": "integer", "minimum": 0, "maximum": 63},
    "anchorZ": {"type": "integer", "minimum": 0, "maximum": 63},
    "allowedRotations": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"enum": ["NONE", "CLOCKWISE_90", "CLOCKWISE_180", "CLOCKWISE_270"]}},
    "placementKind": {"enum": ["WATER_EDGE", "WATER_CROSSING", "DRY_FLAT", "DRY_FOLLOWING"]},
    "maximumSlope": {"type": "integer", "minimum": 0, "maximum": 32},
    "waterAllowed": {"type": "boolean"}
  }
}
