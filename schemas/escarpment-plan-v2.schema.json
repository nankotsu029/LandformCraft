{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/escarpment-plan-v2.schema.json",
  "title": "LandformCraft V2-10-06 escarpment foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-06 escarpment foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "centerline", "selectedScarpHeightBlocks",
    "selectedTalusWidthBlocks", "selectedFloorDropBlocks", "dropSide",
    "plateauTransitionBandBlocks", "minY", "maxY", "width", "length",
    "faceMaskFieldId", "talusMaskFieldId", "floorMaskFieldId",
    "ownershipFieldId", "materialHandoffFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "centerline": { "type": "array", "minItems": 2, "maxItems": 16384, "items": { "$ref": "#/$defs/centerlinePoint" } },
    "selectedScarpHeightBlocks": { "type": "integer", "minimum": 4, "maximum": 128 },
    "selectedTalusWidthBlocks": { "type": "integer", "minimum": 2, "maximum": 64 },
    "selectedFloorDropBlocks": { "type": "integer", "minimum": 4, "maximum": 128 },
    "dropSide": { "enum": ["NORTH", "EAST", "SOUTH", "WEST"] },
    "plateauTransitionBandBlocks": { "type": "integer", "minimum": 2, "maximum": 32 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "width": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "faceMaskFieldId": { "const": "foundation.escarpment.face-mask" },
    "talusMaskFieldId": { "const": "foundation.escarpment.talus-mask" },
    "floorMaskFieldId": { "const": "foundation.escarpment.floor-mask" },
    "ownershipFieldId": { "const": "foundation.escarpment.ownership" },
    "materialHandoffFieldId": { "const": "foundation.escarpment.material-handoff" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "centerlinePoint": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths", "arcLengthMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "arcLengthMillionths": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
