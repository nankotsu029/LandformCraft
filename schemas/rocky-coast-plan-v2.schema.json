{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/rocky-coast-plan-v2.schema.json",
  "title": "LandformCraft V2-9-06 rocky-coast foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-9-06 rocky-coast foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "centerline", "selectedRockShelfWidthBlocks",
    "selectedRockExposureMillionths", "shoreSide", "selectedChannelCount",
    "capeOrBeachTransitionBandBlocks", "talusHandoffDepthBlocks",
    "minY", "maxY", "waterLevel", "width", "length",
    "shelfMaskFieldId", "exposureFieldId", "channelMaskFieldId",
    "talusHandoffFieldId", "solidOwnershipFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "centerline": { "type": "array", "minItems": 2, "maxItems": 16384, "items": { "$ref": "#/$defs/centerlinePoint" } },
    "selectedRockShelfWidthBlocks": { "type": "integer", "minimum": 1, "maximum": 64 },
    "selectedRockExposureMillionths": { "type": "integer", "minimum": 50000, "maximum": 1000000 },
    "shoreSide": { "enum": ["NORTH", "EAST", "SOUTH", "WEST"] },
    "selectedChannelCount": { "type": "integer", "minimum": 1, "maximum": 8 },
    "capeOrBeachTransitionBandBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
    "talusHandoffDepthBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "waterLevel": { "type": "integer" },
    "width": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "shelfMaskFieldId": { "const": "foundation.rocky-coast.shelf-mask" },
    "exposureFieldId": { "const": "foundation.rocky-coast.exposure" },
    "channelMaskFieldId": { "const": "foundation.rocky-coast.channel-mask" },
    "talusHandoffFieldId": { "const": "foundation.rocky-coast.talus-handoff" },
    "solidOwnershipFieldId": { "const": "foundation.rocky-coast.solid-ownership" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 64000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "centerlinePoint": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths", "arcLengthMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "arcLengthMillionths": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
