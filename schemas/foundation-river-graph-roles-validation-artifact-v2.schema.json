{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/foundation-river-graph-roles-validation-artifact-v2.schema.json",
  "title": "LandformCraft V2-9-13 river graph roles validation artifact",
  "description": "Strict, version-frozen v2 contract for the V2-9-13 river graph roles validation artifact. Validation evidence only; it never authorizes generation or world mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "riverFeatureId", "waterfallChainId",
    "metrics", "issues", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "foundation-river-graph-roles-validation-artifact-v1" },
    "riverFeatureId": { "$ref": "#/$defs/slug" },
    "waterfallChainId": { "type": "string", "maxLength": 64 },
    "metrics": { "$ref": "#/$defs/metrics" },
    "issues": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/issue" } },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": [
        "sourceMouthReachable", "flowConservationOk", "elevationContinuityOk",
        "modifierOrderOk", "childOwnershipOk", "waterfallChainOk",
        "graphBudgetOk", "cycleFree", "wholeTileOk"
      ],
      "properties": {
        "sourceMouthReachable": { "type": "boolean" },
        "flowConservationOk": { "type": "boolean" },
        "elevationContinuityOk": { "type": "boolean" },
        "modifierOrderOk": { "type": "boolean" },
        "childOwnershipOk": { "type": "boolean" },
        "waterfallChainOk": { "type": "boolean" },
        "graphBudgetOk": { "type": "boolean" },
        "cycleFree": { "type": "boolean" },
        "wholeTileOk": { "type": "boolean" }
      }
    },
    "issue": {
      "type": "object", "additionalProperties": false,
      "required": ["ruleId", "message"],
      "properties": {
        "ruleId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
        "message": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
