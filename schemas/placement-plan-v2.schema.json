{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/placement-plan-v2.schema.json",
  "title": "LandformCraft V2-6-01 Release 2 placement plan contract",
  "description": "Strict, version-frozen v2 contract for the V2-6-01 Release 2 placement plan contract. Read and written by the Release 2 placement lifecycle with strict read-back.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "placementContractVersion", "placementId", "operationId", "requestId",
    "actor", "target", "releaseBinding", "requiredCapabilities", "tileOrder",
    "envelopeReferences", "reservationConfirmationBinding", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": {"const": 1},
    "placementContractVersion": {"const": "release-2-placement-contract-v1"},
    "placementId": {"type": "string", "format": "uuid"},
    "operationId": {"type": "string", "format": "uuid"},
    "requestId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "actor": {"$ref": "#/$defs/actor"},
    "target": {"$ref": "#/$defs/target"},
    "releaseBinding": {"$ref": "#/$defs/releaseBinding"},
    "requiredCapabilities": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": ["environment-fields", "hydrology-plan", "sparse-volume", "surface-2_5d"]
      }
    },
    "tileOrder": {"$ref": "#/$defs/tileOrder"},
    "envelopeReferences": {"$ref": "#/$defs/envelopeReferences"},
    "reservationConfirmationBinding": {"$ref": "#/$defs/reservationConfirmationBinding"},
    "budget": {"$ref": "#/$defs/budget"},
    "canonicalChecksum": {"$ref": "#/$defs/checksum"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"enum": ["PLAYER", "CONSOLE", "SYSTEM"]},
        "id": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worldId", "worldName", "anchorKind", "anchorX", "anchorY", "anchorZ",
        "minimumX", "minimumY", "minimumZ", "maximumX", "maximumY", "maximumZ"
      ],
      "properties": {
        "worldId": {"type": "string", "format": "uuid"},
        "worldName": {"type": "string", "minLength": 1, "maxLength": 128},
        "anchorKind": {"const": "MINIMUM_CORNER"},
        "anchorX": {"type": "integer"},
        "anchorY": {"type": "integer"},
        "anchorZ": {"type": "integer"},
        "minimumX": {"type": "integer"},
        "minimumY": {"type": "integer"},
        "minimumZ": {"type": "integer"},
        "maximumX": {"type": "integer"},
        "maximumY": {"type": "integer"},
        "maximumZ": {"type": "integer"}
      }
    },
    "releaseBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingVersion", "releaseFormatVersion", "releaseDirectory",
        "manifestChecksum", "bindingContractVersion"
      ],
      "properties": {
        "bindingVersion": {"const": 1},
        "releaseFormatVersion": {"const": 2},
        "releaseDirectory": {
          "type": "string",
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*//).+$"
        },
        "manifestChecksum": {"$ref": "#/$defs/checksum"},
        "bindingContractVersion": {"const": "release-2-placement-release-binding-v1"}
      }
    },
    "tileOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orderingContractVersion", "tiles"],
      "properties": {
        "orderingContractVersion": {"const": "release-2-placement-tile-order-v1"},
        "tiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1024,
          "items": {"$ref": "#/$defs/tileRef"}
        }
      }
    },
    "tileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tileId", "tileIndex", "coreMinX", "coreMinZ", "coreWidth", "coreLength"],
      "properties": {
        "tileId": {"type": "string", "pattern": "^tile-x[0-9]+-z[0-9]+$"},
        "tileIndex": {"type": "integer", "minimum": 0, "maximum": 1023},
        "coreMinX": {"type": "integer"},
        "coreMinZ": {"type": "integer"},
        "coreWidth": {"type": "integer", "minimum": 1},
        "coreLength": {"type": "integer", "minimum": 1}
      }
    },
    "envelopeReferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingContractVersion", "bound",
        "mutationEnvelopePlanChecksum", "effectEnvelopePlanChecksum"
      ],
      "properties": {
        "bindingContractVersion": {"const": "release-2-placement-envelope-ref-v1"},
        "bound": {"type": "boolean"},
        "mutationEnvelopePlanChecksum": {"$ref": "#/$defs/checksum"},
        "effectEnvelopePlanChecksum": {"$ref": "#/$defs/checksum"}
      }
    },
    "reservationConfirmationBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingContractVersion", "reservationBound", "reservationChecksum",
        "confirmationIssued", "confirmationAction", "confirmationActor",
        "confirmationHash", "confirmationCreatedAt", "confirmationExpiresAt"
      ],
      "properties": {
        "bindingContractVersion": {"const": "release-2-placement-reservation-confirm-binding-v1"},
        "reservationBound": {"type": "boolean"},
        "reservationChecksum": {"$ref": "#/$defs/checksum"},
        "confirmationIssued": {"type": "boolean"},
        "confirmationAction": {
          "enum": ["NONE", "APPLY", "UNDO", "RECOVERY_ROLLBACK", "RECOVERY_ACCEPT"]
        },
        "confirmationActor": {"$ref": "#/$defs/actor"},
        "confirmationHash": {"type": "string", "pattern": "^(?:|[0-9a-f]{64})$"},
        "confirmationCreatedAt": {"type": "string", "format": "date-time"},
        "confirmationExpiresAt": {"type": "string", "format": "date-time"}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budgetVersion", "maximumTiles", "maximumJournalEntries",
        "estimatedCanonicalBytes", "maximumCanonicalBytes", "maximumWorkingBytes"
      ],
      "properties": {
        "budgetVersion": {"const": "release-2-placement-budget-v1"},
        "maximumTiles": {"type": "integer", "minimum": 1, "maximum": 1024},
        "maximumJournalEntries": {"type": "integer", "minimum": 1, "maximum": 1024},
        "estimatedCanonicalBytes": {"type": "integer", "minimum": 1},
        "maximumCanonicalBytes": {"type": "integer", "minimum": 1, "maximum": 262144},
        "maximumWorkingBytes": {"type": "integer", "minimum": 1}
      }
    }
  }
}
