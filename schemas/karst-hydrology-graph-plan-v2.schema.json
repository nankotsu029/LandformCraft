{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/karst-hydrology-graph-plan-v2.schema.json",
  "title": "LandformCraft V2-10-03 karst hydrology graph plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-03 karst hydrology graph plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "graphId", "contractVersion", "nodes", "edges", "sinkholeFeatureId",
    "springFeatureId", "caveNetworkFeatureId", "caveNetworkCanonicalChecksum",
    "undergroundRiverFeatureId", "undergroundRiverPlanChecksum", "sinkholePlanChecksum",
    "springPlanChecksum", "lossVolumeBlocks", "springDischargeBlocks", "materialHandoffId",
    "supportRadiusXZ", "estimatedWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "graphId": { "$ref": "#/$defs/slug" },
    "contractVersion": { "const": "karst-hydrology-graph-plan-contract-v1" },
    "nodes": { "type": "array", "minItems": 3, "maxItems": 16, "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/edge" } },
    "sinkholeFeatureId": { "$ref": "#/$defs/slug" },
    "springFeatureId": { "$ref": "#/$defs/slug" },
    "caveNetworkFeatureId": { "$ref": "#/$defs/slug" },
    "caveNetworkCanonicalChecksum": { "$ref": "#/$defs/checksum" },
    "undergroundRiverFeatureId": { "type": "string", "maxLength": 64 },
    "undergroundRiverPlanChecksum": { "type": "string", "maxLength": 64 },
    "sinkholePlanChecksum": { "$ref": "#/$defs/checksum" },
    "springPlanChecksum": { "$ref": "#/$defs/checksum" },
    "lossVolumeBlocks": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "springDischargeBlocks": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "materialHandoffId": { "const": "karst-limestone-handoff" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nodeRole": {
      "type": "string",
      "enum": ["SINKHOLE", "UNDERGROUND_RIVER", "KARST_CAVE_SYSTEM", "KARST_SPRING"]
    },
    "relationKind": {
      "type": "string",
      "enum": ["DRAINS_TO", "WITHIN", "ORIGINATES_AT", "ENTRANCE_OF", "EMPTIES_INTO", "UPSTREAM_OF"]
    },
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["nodeId", "role", "featureId", "planChecksum"],
      "properties": {
        "nodeId": { "$ref": "#/$defs/slug" },
        "role": { "$ref": "#/$defs/nodeRole" },
        "featureId": { "$ref": "#/$defs/slug" },
        "planChecksum": { "$ref": "#/$defs/checksum" }
      }
    },
    "edge": {
      "type": "object", "additionalProperties": false,
      "required": ["edgeId", "fromNodeId", "toNodeId", "relationKind"],
      "properties": {
        "edgeId": { "$ref": "#/$defs/slug" },
        "fromNodeId": { "$ref": "#/$defs/slug" },
        "toNodeId": { "$ref": "#/$defs/slug" },
        "relationKind": { "$ref": "#/$defs/relationKind" }
      }
    }
  }
}
