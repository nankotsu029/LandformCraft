{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/strata-plan-v2.schema.json",
  "title": "LandformCraft V2-4 strata profiles and hydrology geology-input handoff",
  "description": "Strict, version-frozen v2 contract for the V2-4 strata profiles and hydrology geology-input handoff. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "profileContractVersion", "sourceGeologyPlanChecksum", "sourceLithologyPlanChecksum",
    "profiles", "hydrologyHandoff", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "profileContractVersion": { "const": "strata-profile-contract-v1" },
    "sourceGeologyPlanChecksum": { "$ref": "#/$defs/checksum" },
    "sourceLithologyPlanChecksum": { "$ref": "#/$defs/checksum" },
    "profiles": {
      "type": "array", "maxItems": 256,
      "items": { "$ref": "#/$defs/profile" }
    },
    "hydrologyHandoff": { "$ref": "#/$defs/hydrologyHandoff" },
    "budget": { "$ref": "#/$defs/budget" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "qualified": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "layer": {
      "type": "object", "additionalProperties": false,
      "required": ["layerIndex", "lithologyId", "lithologyCode", "thicknessBlocks"],
      "properties": {
        "layerIndex": { "type": "integer", "minimum": 0, "maximum": 15 },
        "lithologyId": { "$ref": "#/$defs/qualified" },
        "lithologyCode": { "type": "integer", "minimum": 1, "maximum": 255 },
        "thicknessBlocks": { "type": "integer", "minimum": 1, "maximum": 512 }
      }
    },
    "foldTilt": {
      "type": "object", "additionalProperties": false,
      "required": [
        "dipDegrees", "dipAzimuthDegrees", "tiltDxMillionths", "tiltDzMillionths",
        "foldAmplitudeBlocks", "foldWavelengthBlocks"
      ],
      "properties": {
        "dipDegrees": { "type": "integer", "minimum": 0, "maximum": 45 },
        "dipAzimuthDegrees": { "type": "integer", "minimum": 0, "maximum": 359 },
        "tiltDxMillionths": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "tiltDzMillionths": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "foldAmplitudeBlocks": { "type": "integer", "minimum": 0, "maximum": 32 },
        "foldWavelengthBlocks": { "type": "integer", "minimum": 0, "maximum": 256 }
      }
    },
    "profile": {
      "type": "object", "additionalProperties": false,
      "required": [
        "profileId", "provinceId", "provinceCode", "formationId", "formationCode",
        "layerOrder", "layers", "orientation"
      ],
      "properties": {
        "profileId": { "$ref": "#/$defs/slug" },
        "provinceId": { "$ref": "#/$defs/slug" },
        "provinceCode": { "type": "integer", "minimum": 1, "maximum": 65534 },
        "formationId": { "$ref": "#/$defs/qualified" },
        "formationCode": { "type": "integer", "minimum": 1, "maximum": 65534 },
        "layerOrder": { "const": "BOTTOM_TO_TOP" },
        "layers": {
          "type": "array", "minItems": 1, "maxItems": 16,
          "items": { "$ref": "#/$defs/layer" }
        },
        "orientation": { "$ref": "#/$defs/foldTilt" }
      }
    },
    "hydrologyHandoff": {
      "type": "object", "additionalProperties": false,
      "required": [
        "bindingVersion", "sourcePriorKind", "sourceHydrologyPriorChecksum",
        "sourceReconciliationAlgorithmVersion", "sourceGeologyPlanChecksum",
        "sourceLithologyPlanChecksum", "inputMode", "transitionMode"
      ],
      "properties": {
        "bindingVersion": { "const": 1 },
        "sourcePriorKind": { "const": "UNIFORM_GEOLOGY_PRIOR" },
        "sourceHydrologyPriorChecksum": { "$ref": "#/$defs/checksum" },
        "sourceReconciliationAlgorithmVersion": { "const": "hydrology-reconcile-fixed-v1" },
        "sourceGeologyPlanChecksum": { "$ref": "#/$defs/checksum" },
        "sourceLithologyPlanChecksum": { "$ref": "#/$defs/checksum" },
        "inputMode": { "const": "SURFACE_EXPOSED_STRATA_SCALARS" },
        "transitionMode": { "const": "EXPLICIT_VERSION_TRANSITION" }
      }
    },
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": [
        "budgetVersion", "maximumProfiles", "maximumLayersPerProfile", "maximumTotalLayers",
        "maximumStackThicknessBlocks", "globalCellCount", "estimatedCpuWorkUnits",
        "estimatedRetainedBytes", "maximumCanonicalBytes"
      ],
      "properties": {
        "budgetVersion": { "const": "strata-profile-budget-v1" },
        "maximumProfiles": { "type": "integer", "minimum": 0, "maximum": 256 },
        "maximumLayersPerProfile": { "const": 16 },
        "maximumTotalLayers": { "type": "integer", "minimum": 1, "maximum": 1024 },
        "maximumStackThicknessBlocks": { "const": 512 },
        "globalCellCount": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "estimatedCpuWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
        "estimatedRetainedBytes": { "type": "integer", "minimum": 1, "maximum": 4194304 },
        "maximumCanonicalBytes": { "type": "integer", "minimum": 1024, "maximum": 131072 }
      }
    }
  }
}
