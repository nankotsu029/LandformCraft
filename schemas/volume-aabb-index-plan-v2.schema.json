{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/volume-aabb-index-plan-v2.schema.json",
  "title": "LandformCraft V2-5-03 VolumePlan AABB index contract",
  "description": "Strict, version-frozen v2 contract for the V2-5-03 VolumePlan AABB index contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "indexContractVersion", "csgPlanBinding", "kernel",
    "entries", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": {"const": 1},
    "indexContractVersion": {"const": "volume-aabb-index-contract-v1"},
    "csgPlanBinding": {"$ref": "#/$defs/csgPlanBinding"},
    "kernel": {"$ref": "#/$defs/kernel"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/entry"}
    },
    "budget": {"$ref": "#/$defs/budget"},
    "canonicalChecksum": {"$ref": "#/$defs/checksum"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "qualified": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "millionths": {"type": "integer", "minimum": -100000000000000, "maximum": 100000000000000},
    "csgPlanBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingVersion", "sourceVolumeCsgPlanChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": {"const": 1},
        "sourceVolumeCsgPlanChecksum": {"$ref": "#/$defs/checksum"},
        "bindingContractVersion": {"const": "volume-aabb-index-csg-binding-v1"}
      }
    },
    "kernel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kernelVersion", "maximumEntries", "maximumQueryResults",
        "maximumSupportBlocksXZ", "maximumSupportBlocksY"
      ],
      "properties": {
        "kernelVersion": {"const": "volume-aabb-index-v1"},
        "maximumEntries": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumQueryResults": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumSupportBlocksXZ": {"type": "integer", "minimum": 0, "maximum": 64},
        "maximumSupportBlocksY": {"type": "integer", "minimum": 0, "maximum": 64}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budgetVersion", "maximumEntries", "maximumQueryResults",
        "estimatedCanonicalBytes", "maximumCanonicalBytes",
        "maximumWorkingBytes", "maximumIndexNodes"
      ],
      "properties": {
        "budgetVersion": {"const": "volume-aabb-index-budget-v1"},
        "maximumEntries": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumQueryResults": {"type": "integer", "minimum": 1, "maximum": 64},
        "estimatedCanonicalBytes": {"type": "integer", "minimum": 1},
        "maximumCanonicalBytes": {"type": "integer", "minimum": 1, "maximum": 65536},
        "maximumWorkingBytes": {"type": "integer", "minimum": 1},
        "maximumIndexNodes": {"type": "integer", "minimum": 1, "maximum": 64}
      }
    },
    "aabb": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minXMillionths", "minYMillionths", "minZMillionths",
        "maxXMillionths", "maxYMillionths", "maxZMillionths"
      ],
      "properties": {
        "minXMillionths": {"$ref": "#/$defs/millionths"},
        "minYMillionths": {"$ref": "#/$defs/millionths"},
        "minZMillionths": {"$ref": "#/$defs/millionths"},
        "maxXMillionths": {"$ref": "#/$defs/millionths"},
        "maxYMillionths": {"$ref": "#/$defs/millionths"},
        "maxZMillionths": {"$ref": "#/$defs/millionths"}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entryId", "operatorId", "ordinal", "aabb",
        "supportRadiusXZBlocks", "supportRadiusYBlocks"
      ],
      "properties": {
        "entryId": {"$ref": "#/$defs/qualified"},
        "operatorId": {"$ref": "#/$defs/qualified"},
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 63},
        "aabb": {"$ref": "#/$defs/aabb"},
        "supportRadiusXZBlocks": {"type": "integer", "minimum": 0, "maximum": 64},
        "supportRadiusYBlocks": {"type": "integer", "minimum": 0, "maximum": 64}
      }
    }
  }
}
