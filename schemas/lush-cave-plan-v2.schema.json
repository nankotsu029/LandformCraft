{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/lush-cave-plan-v2.schema.json",
  "title": "LandformCraft V2-5-07 LUSH_CAVE plan contract",
  "description": "Strict, version-frozen v2 contract for the V2-5-07 LUSH_CAVE plan contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "lushContractVersion", "featureId", "kernel", "hostBinding",
    "reachableFrom", "chamber", "wetCondition", "ecologyHook", "aabb",
    "surfaceHeightBlocks", "sdfPlanBinding", "csgPlanBinding", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": {"const": 1},
    "lushContractVersion": {"const": "lush-cave-contract-v1"},
    "featureId": {"$ref": "#/$defs/qualified"},
    "kernel": {"$ref": "#/$defs/kernel"},
    "hostBinding": {"$ref": "#/$defs/hostBinding"},
    "reachableFrom": {"$ref": "#/$defs/reachableFrom"},
    "chamber": {"$ref": "#/$defs/chamber"},
    "wetCondition": {"$ref": "#/$defs/wetCondition"},
    "ecologyHook": {"$ref": "#/$defs/ecologyHook"},
    "aabb": {"$ref": "#/$defs/aabb"},
    "surfaceHeightBlocks": {"type": "integer", "minimum": -512, "maximum": 512},
    "sdfPlanBinding": {"$ref": "#/$defs/sdfBinding"},
    "csgPlanBinding": {"$ref": "#/$defs/csgBinding"},
    "budget": {"$ref": "#/$defs/budget"},
    "canonicalChecksum": {"$ref": "#/$defs/checksum"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "qualified": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "millionths": {"type": "integer", "minimum": -100000000000000, "maximum": 100000000000000},
    "vec3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xMillionths", "yMillionths", "zMillionths"],
      "properties": {
        "xMillionths": {"$ref": "#/$defs/millionths"},
        "yMillionths": {"$ref": "#/$defs/millionths"},
        "zMillionths": {"$ref": "#/$defs/millionths"}
      }
    },
    "aabb": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minXMillionths", "minYMillionths", "minZMillionths",
        "maxXMillionths", "maxYMillionths", "maxZMillionths"
      ],
      "properties": {
        "minXMillionths": {"$ref": "#/$defs/millionths"},
        "minYMillionths": {"$ref": "#/$defs/millionths"},
        "minZMillionths": {"$ref": "#/$defs/millionths"},
        "maxXMillionths": {"$ref": "#/$defs/millionths"},
        "maxYMillionths": {"$ref": "#/$defs/millionths"},
        "maxZMillionths": {"$ref": "#/$defs/millionths"}
      }
    },
    "kernel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kernelVersion", "minimumRoofBlocks", "minimumMoistureMillionths",
        "minimumCeilingClearanceBlocks", "maximumRadiusMillionths", "maximumDescriptorSamples"
      ],
      "properties": {
        "kernelVersion": {"const": "lush-cave-v1"},
        "minimumRoofBlocks": {"type": "integer", "minimum": 1, "maximum": 64},
        "minimumMoistureMillionths": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "minimumCeilingClearanceBlocks": {"type": "integer", "minimum": 1, "maximum": 64},
        "maximumRadiusMillionths": {"type": "integer", "minimum": 1000000, "maximum": 30000000},
        "maximumDescriptorSamples": {"type": "integer", "minimum": 1, "maximum": 64000}
      }
    },
    "hostBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationKind", "hostNetworkFeatureId", "hostNetworkPlanChecksum", "hostChamberNodeId"
      ],
      "properties": {
        "relationKind": {"const": "WITHIN"},
        "hostNetworkFeatureId": {"$ref": "#/$defs/qualified"},
        "hostNetworkPlanChecksum": {"$ref": "#/$defs/checksum"},
        "hostChamberNodeId": {"$ref": "#/$defs/qualified"}
      }
    },
    "reachableFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationKind", "entranceNodeId"],
      "properties": {
        "relationKind": {"const": "REACHABLE_FROM"},
        "entranceNodeId": {"$ref": "#/$defs/qualified"}
      }
    },
    "chamber": {
      "type": "object",
      "additionalProperties": false,
      "required": ["center", "radiusMillionths", "ceilingClearanceBlocks"],
      "properties": {
        "center": {"$ref": "#/$defs/vec3"},
        "radiusMillionths": {"type": "integer", "minimum": 1000000, "maximum": 30000000},
        "ceilingClearanceBlocks": {"type": "integer", "minimum": 1, "maximum": 64}
      }
    },
    "wetCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["moistureMillionths", "poolShareMillionths", "eligibleSurfaceClasses"],
      "properties": {
        "moistureMillionths": {"type": "integer", "minimum": 0, "maximum": 1000000},
        "poolShareMillionths": {"type": "integer", "minimum": 0, "maximum": 1000000},
        "eligibleSurfaceClasses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {"enum": ["FLOOR", "WALL", "CEILING"]}
        }
      }
    },
    "ecologyHook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hookVersion", "ecologyPreset", "reservedAssemblageIds"],
      "properties": {
        "hookVersion": {"const": "lush-cave-ecology-hook-v1"},
        "ecologyPreset": {"const": "LUSH_SUBTERRANEAN"},
        "reservedAssemblageIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/qualified"}
        }
      }
    },
    "sdfBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingVersion", "sourceArtifactChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": {"const": 1},
        "sourceArtifactChecksum": {"$ref": "#/$defs/checksum"},
        "bindingContractVersion": {"const": "lush-cave-sdf-binding-v1"}
      }
    },
    "csgBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingVersion", "sourceArtifactChecksum", "bindingContractVersion"],
      "properties": {
        "bindingVersion": {"const": 1},
        "sourceArtifactChecksum": {"$ref": "#/$defs/checksum"},
        "bindingContractVersion": {"const": "lush-cave-csg-binding-v1"}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budgetVersion", "estimatedCanonicalBytes", "maximumCanonicalBytes",
        "maximumWorkingBytes", "maximumDescriptorSamples"
      ],
      "properties": {
        "budgetVersion": {"const": "lush-cave-budget-v1"},
        "estimatedCanonicalBytes": {"type": "integer", "minimum": 1},
        "maximumCanonicalBytes": {"type": "integer", "minimum": 1, "maximum": 49152},
        "maximumWorkingBytes": {"type": "integer", "minimum": 1},
        "maximumDescriptorSamples": {"type": "integer", "minimum": 1, "maximum": 64000}
      }
    }
  }
}
