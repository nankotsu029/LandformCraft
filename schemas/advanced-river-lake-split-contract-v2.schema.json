{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/advanced-river-lake-split-contract-v2.schema.json",
  "title": "LandformCraft V2-10-05 advanced river/lake split contract",
  "description": "Strict, version-frozen v2 contract for the V2-10-05 advanced river/lake split contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "decisionId", "selectedTaskIds", "selectedKinds",
    "candidates", "riskExclusions", "compatibilityNotes", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "advanced-river-lake-split-contract-v1" },
    "decisionId": { "const": "v2-10-05-advanced-river-lake-split" },
    "selectedTaskIds": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "string", "enum": ["V2-10-10", "V2-10-11"] }
    },
    "selectedKinds": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "string", "enum": ["OXBOW_LAKE", "SPRING"] }
    },
    "candidates": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "riskExclusions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/riskExclusion" }
    },
    "compatibilityNotes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ownershipModel", "disposition", "rationale"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "ALLUVIAL_FAN", "BRAIDED_RIVER", "DAM_RESERVOIR", "ESTUARY",
            "OXBOW_LAKE", "RIVER_TERRACE", "SPRING"
          ]
        },
        "ownershipModel": {
          "type": "string",
          "enum": [
            "GRAPH_SOURCE_NODE", "REACH_CUTOFF_BASIN", "REACH_PROFILE", "SEDIMENT_FAN",
            "MOUTH_COMPOSITION", "MULTI_CHANNEL_DAG", "BARRIER_BASIN"
          ]
        },
        "disposition": {
          "type": "string",
          "enum": [
            "FIRST_SLICE", "DEFERRED_STANDALONE", "DEFERRED_CHILD_OR_PROFILE",
            "DEFERRED_COMPOSITION", "DEFERRED_BARRIER"
          ]
        },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "riskExclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leftKind", "rightKind", "reason"],
      "properties": {
        "leftKind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "rightKind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
