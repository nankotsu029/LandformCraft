{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/abyssal-plain-plan-v2.schema.json",
  "title": "LandformCraft V2-10-04 abyssal-plain foundation plan",
  "description": "Strict, version-frozen v2 contract for the V2-10-04 abyssal-plain foundation plan. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "basinFeatureId", "basinGeometryChecksum", "basinRelationId",
    "rings", "selectedFloorDepthBlocksBelowSea", "selectedFloorReliefBlocks",
    "width", "length", "minY", "maxY", "waterLevel",
    "depthFieldId", "ownershipFieldId", "reliefFieldId", "fluidColumnHintFieldId",
    "supportRadiusXZ", "estimatedRasterWorkUnits", "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "basinFeatureId": { "$ref": "#/$defs/slug" },
    "basinGeometryChecksum": { "$ref": "#/$defs/checksum" },
    "basinRelationId": { "$ref": "#/$defs/slug" },
    "rings": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/ring" } },
    "selectedFloorDepthBlocksBelowSea": { "type": "integer", "minimum": 16, "maximum": 256 },
    "selectedFloorReliefBlocks": { "type": "integer", "minimum": 0, "maximum": 8 },
    "width": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1024 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "waterLevel": { "type": "integer" },
    "depthFieldId": { "const": "foundation.abyssal-plain.depth" },
    "ownershipFieldId": { "const": "foundation.abyssal-plain.ownership" },
    "reliefFieldId": { "const": "foundation.abyssal-plain.relief" },
    "fluidColumnHintFieldId": { "const": "foundation.abyssal-plain.fluid-column-hint" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedRasterWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vertex": {
      "type": "object", "additionalProperties": false,
      "required": ["xMillionths", "zMillionths"],
      "properties": {
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 }
      }
    },
    "ring": {
      "type": "object", "additionalProperties": false,
      "required": ["vertices"],
      "properties": {
        "vertices": {
          "type": "array", "minItems": 4, "maxItems": 2048,
          "items": { "$ref": "#/$defs/vertex" }
        }
      }
    }
  }
}
