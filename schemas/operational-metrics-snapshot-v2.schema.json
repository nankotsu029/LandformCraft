{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/operational-metrics-snapshot-v2.schema.json",
  "title": "LandformCraft OperationalMetricsSnapshotV2",
  "description": "Strict, version-frozen v2 contract for the OperationalMetricsSnapshotV2. Operational telemetry record; it carries no secrets and no world mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contractVersion", "capturedAt", "samples", "canonicalChecksum"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contractVersion": { "const": "operational-metrics-snapshot-v1" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/sample" }
    },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "unit", "value"],
      "properties": {
        "label": {
          "enum": [
            "GENERATION_QUEUE_DEPTH", "GENERATION_ACTIVE_TASKS", "GENERATION_QUEUE_CAPACITY",
            "IO_AVAILABLE_PERMITS", "IN_FLIGHT_TASKS", "DISK_USABLE_BYTES",
            "MEMORY_HEAP_USED_BYTES", "MEMORY_HEAP_MAX_BYTES",
            "PLACEMENT_STAGE_PLANNED", "PLACEMENT_STAGE_APPLYING", "PLACEMENT_STAGE_SETTLING",
            "PLACEMENT_STAGE_VERIFYING", "PLACEMENT_STAGE_RECOVERY_REQUIRED",
            "PLACEMENT_STAGE_TERMINAL", "SETTLE_TICKS_OBSERVED", "VERIFY_SCANNED_BLOCKS",
            "RUNNING_GENERATION_JOBS"
          ]
        },
        "unit": { "enum": ["COUNT", "BYTES", "TICKS"] },
        "value": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
