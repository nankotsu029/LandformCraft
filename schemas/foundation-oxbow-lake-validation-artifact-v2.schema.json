{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/foundation-oxbow-lake-validation-artifact-v2.schema.json",
  "title": "LandformCraft V2-10-11 oxbow lake foundation validation artifact",
  "description": "Strict, version-frozen v2 contract for the V2-10-11 oxbow lake foundation validation artifact. Validation evidence only; it never authorizes generation or world mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "oxbowFeatureId", "metrics", "issues", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "foundation-oxbow-lake-validation-artifact-v1" },
    "oxbowFeatureId": { "type": "string", "maxLength": 64 },
    "metrics": { "$ref": "#/$defs/metrics" },
    "issues": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/issue" } },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": [
        "cutoffOwnershipOk", "parentRiverBindOk", "stagnantLevelOk", "rimClosedOk",
        "wetlandHandoffOk", "budgetOk", "wholeTileOk", "exportOk", "orphanFree"
      ],
      "properties": {
        "cutoffOwnershipOk": { "type": "boolean" },
        "parentRiverBindOk": { "type": "boolean" },
        "stagnantLevelOk": { "type": "boolean" },
        "rimClosedOk": { "type": "boolean" },
        "wetlandHandoffOk": { "type": "boolean" },
        "budgetOk": { "type": "boolean" },
        "wholeTileOk": { "type": "boolean" },
        "exportOk": { "type": "boolean" },
        "orphanFree": { "type": "boolean" }
      }
    },
    "issue": {
      "type": "object", "additionalProperties": false,
      "required": ["ruleId", "message"],
      "properties": {
        "ruleId": { "type": "string", "maxLength": 64 },
        "message": { "type": "string", "maxLength": 512 }
      }
    }
  }
}
