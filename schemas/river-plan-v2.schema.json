{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/river-plan-v2.schema.json",
  "title": "LandformCraft V2-9 general river foundation plan (roles V2-9-13)",
  "description": "Strict, version-frozen v2 contract for the V2-9 general river foundation plan (roles V2-9-13). Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "featureId", "dischargeClass", "nodes", "reaches", "children", "centerline",
    "totalArcLengthMillionths", "sourceBedYMillionths", "mouthBedYMillionths",
    "selectedBankfullWidthBlocks", "bankWidthBlocks", "floodplainHandoffWidthBlocks",
    "minimumBedSlopeMillionths", "selectedDischargeIndex",
    "minY", "maxY", "waterLevel", "width", "length",
    "channelMaskFieldId", "bankMaskFieldId", "floodplainMaskFieldId", "bedElevationFieldId",
    "dischargeIndexFieldId", "supportRadiusXZ", "estimatedGraphWorkUnits",
    "geometryChecksum", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "featureId": { "$ref": "#/$defs/slug" },
    "dischargeClass": { "enum": ["SMALL", "MEDIUM", "LARGE"] },
    "nodes": { "type": "array", "minItems": 2, "maxItems": 32, "items": { "$ref": "#/$defs/node" } },
    "reaches": { "type": "array", "minItems": 1, "maxItems": 24, "items": { "$ref": "#/$defs/reach" } },
    "children": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/childFeature" } },
    "centerline": { "type": "array", "minItems": 2, "maxItems": 2048, "items": { "$ref": "#/$defs/centerlineSample" } },
    "totalArcLengthMillionths": { "type": "integer", "minimum": 0 },
    "sourceBedYMillionths": { "type": "integer" },
    "mouthBedYMillionths": { "type": "integer" },
    "selectedBankfullWidthBlocks": { "type": "integer", "minimum": 2, "maximum": 64 },
    "bankWidthBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
    "floodplainHandoffWidthBlocks": { "type": "integer", "minimum": 2, "maximum": 128 },
    "minimumBedSlopeMillionths": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "selectedDischargeIndex": { "type": "integer", "minimum": 1, "maximum": 3 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "waterLevel": { "type": "integer" },
    "width": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "length": { "type": "integer", "minimum": 2, "maximum": 1000 },
    "channelMaskFieldId": { "const": "foundation.river.channel-mask" },
    "bankMaskFieldId": { "const": "foundation.river.bank-mask" },
    "floodplainMaskFieldId": { "const": "foundation.river.floodplain-mask" },
    "bedElevationFieldId": { "const": "foundation.river.bed-elevation" },
    "dischargeIndexFieldId": { "const": "foundation.river.discharge-index" },
    "supportRadiusXZ": { "type": "integer", "minimum": 1, "maximum": 64 },
    "estimatedGraphWorkUnits": { "type": "integer", "minimum": 1, "maximum": 64000000 },
    "geometryChecksum": { "$ref": "#/$defs/checksum" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nodeKind": { "enum": ["SOURCE", "CONFLUENCE", "BIFURCATION", "WATERFALL", "MOUTH"] },
    "nodeRole": { "enum": ["NONE", "HEADWATER"] },
    "reachClass": { "enum": ["MAIN_STEM", "STREAM", "TRIBUTARY", "DISTRIBUTARY"] },
    "reachModifier": { "enum": ["RAPIDS"] },
    "childKind": { "enum": ["SANDBAR", "RIVER_ISLAND", "PLUNGE_POOL"] },
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["nodeId", "kind", "role", "xMillionths", "zMillionths", "bedYMillionths"],
      "properties": {
        "nodeId": { "$ref": "#/$defs/slug" },
        "kind": { "$ref": "#/$defs/nodeKind" },
        "role": { "$ref": "#/$defs/nodeRole" },
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "bedYMillionths": { "type": "integer" }
      }
    },
    "reach": {
      "type": "object", "additionalProperties": false,
      "required": ["reachId", "fromNodeId", "toNodeId", "reachClass", "modifiers", "dischargeShareMillionths"],
      "properties": {
        "reachId": { "$ref": "#/$defs/slug" },
        "fromNodeId": { "$ref": "#/$defs/slug" },
        "toNodeId": { "$ref": "#/$defs/slug" },
        "reachClass": { "$ref": "#/$defs/reachClass" },
        "modifiers": {
          "type": "array", "maxItems": 8,
          "items": { "$ref": "#/$defs/reachModifier" }
        },
        "dischargeShareMillionths": { "type": "integer", "minimum": 1, "maximum": 1000000 }
      }
    },
    "childFeature": {
      "type": "object", "additionalProperties": false,
      "required": [
        "childId", "kind", "ownerReachId", "ownerNodeId",
        "xMillionths", "zMillionths", "radiusBlocks", "ownershipPriority"
      ],
      "properties": {
        "childId": { "$ref": "#/$defs/slug" },
        "kind": { "$ref": "#/$defs/childKind" },
        "ownerReachId": { "type": "string", "maxLength": 64 },
        "ownerNodeId": { "type": "string", "maxLength": 64 },
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "radiusBlocks": { "type": "integer", "minimum": 1, "maximum": 32 },
        "ownershipPriority": { "type": "integer", "minimum": 1, "maximum": 64 }
      }
    },
    "centerlineSample": {
      "type": "object", "additionalProperties": false,
      "required": ["sequence", "xMillionths", "zMillionths", "arcLengthMillionths", "bedYMillionths"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "xMillionths": { "type": "integer", "minimum": 0 },
        "zMillionths": { "type": "integer", "minimum": 0 },
        "arcLengthMillionths": { "type": "integer", "minimum": 0 },
        "bedYMillionths": { "type": "integer" }
      }
    }
  }
}
