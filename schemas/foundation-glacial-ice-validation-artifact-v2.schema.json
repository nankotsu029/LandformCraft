{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/foundation-glacial-ice-validation-artifact-v2.schema.json",
  "title": "LandformCraft V2-10-01 glacial-ice foundation validation artifact",
  "description": "Strict, version-frozen v2 contract for the V2-10-01 glacial-ice foundation validation artifact. Validation evidence only; it never authorizes generation or world mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "contractVersion", "iceFeatureId", "metrics", "issues", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "contractVersion": { "const": "foundation-glacial-ice-validation-artifact-v1" },
    "iceFeatureId": { "type": "string", "maxLength": 64 },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": [
        "coldClimateOk", "bedContactOk", "flowTerminusOk", "sparseIceOk",
        "meltwaterHandoffOk", "leakFree", "wholeTileOk", "budgetOk", "exportOk"
      ],
      "properties": {
        "coldClimateOk": { "type": "boolean" },
        "bedContactOk": { "type": "boolean" },
        "flowTerminusOk": { "type": "boolean" },
        "sparseIceOk": { "type": "boolean" },
        "meltwaterHandoffOk": { "type": "boolean" },
        "leakFree": { "type": "boolean" },
        "wholeTileOk": { "type": "boolean" },
        "budgetOk": { "type": "boolean" },
        "exportOk": { "type": "boolean" }
      }
    },
    "issues": {
      "type": "array", "maxItems": 256,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["ruleId", "message"],
        "properties": {
          "ruleId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
          "message": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      }
    },
    "canonicalChecksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
