{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nankotsu029/LandformCraft/schemas/v2/climate-plan-v2.schema.json",
  "title": "LandformCraft V2-4 climate prior and final field contract",
  "description": "Strict, version-frozen v2 contract for the V2-4 climate prior and final field contract. Compiled offline from TerrainIntent v2 and re-read with strict validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion", "fieldContractVersion", "baseClimatePreset",
    "priorModuleId", "priorModuleVersion", "priorStageId",
    "finalModuleId", "finalModuleVersion", "finalStageId",
    "namedSeed", "seedNamespace", "width", "length", "minY", "maxY", "referenceElevationY",
    "coarsePrior", "finalKernel", "hydrologyHandoff", "fields", "budget", "canonicalChecksum"
  ],
  "properties": {
    "planVersion": { "const": 1 },
    "fieldContractVersion": { "const": "climate-field-contract-v1" },
    "baseClimatePreset": { "$ref": "#/$defs/baseClimatePreset" },
    "priorModuleId": { "const": "v2.environment.climate-prior" },
    "priorModuleVersion": { "const": "0.1.0-v2-4-04" },
    "priorStageId": { "const": "generate.climate-prior" },
    "finalModuleId": { "const": "v2.environment.climate-final" },
    "finalModuleVersion": { "const": "0.1.0-v2-4-04" },
    "finalStageId": { "const": "generate.climate-final" },
    "namedSeed": { "type": "integer" },
    "seedNamespace": { "const": "terrain.v2.climate" },
    "width": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "length": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "minY": { "type": "integer" },
    "maxY": { "type": "integer" },
    "referenceElevationY": { "type": "integer" },
    "coarsePrior": { "$ref": "#/$defs/coarsePrior" },
    "finalKernel": { "$ref": "#/$defs/finalKernel" },
    "hydrologyHandoff": { "$ref": "#/$defs/hydrologyHandoff" },
    "fields": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": { "$ref": "#/$defs/fieldBinding" }
    },
    "budget": { "$ref": "#/$defs/budget" },
    "canonicalChecksum": { "$ref": "#/$defs/checksum" }
  },
  "$defs": {
    "qualified": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "baseClimatePreset": {
      "enum": [
        "COLD_ALPINE", "COLD_MARITIME", "COOL_HIGH_ALTITUDE", "SEASONAL_SEMI_ARID",
        "TEMPERATE_HUMID", "TEMPERATE_MARITIME", "WARM_HUMID", "WARM_HUMID_MARITIME",
        "WARM_MARITIME", "WARM_TROPICAL_MARITIME"
      ]
    },
    "coarsePrior": {
      "type": "object", "additionalProperties": false,
      "required": [
        "kernelVersion", "coarseCellSize", "coarseWidth", "coarseLength",
        "northPrecipitationRaw", "southPrecipitationRaw", "runoffCoefficientRaw", "priorChecksum"
      ],
      "properties": {
        "kernelVersion": { "const": "climate-coarse-prior-v1" },
        "coarseCellSize": { "type": "integer", "minimum": 8, "maximum": 128 },
        "coarseWidth": { "type": "integer", "minimum": 1, "maximum": 126 },
        "coarseLength": { "type": "integer", "minimum": 1, "maximum": 126 },
        "northPrecipitationRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "southPrecipitationRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "runoffCoefficientRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "priorChecksum": { "$ref": "#/$defs/checksum" }
      }
    },
    "finalKernel": {
      "type": "object", "additionalProperties": false,
      "required": [
        "kernelVersion", "baseTemperatureRaw", "latitudeCoolingRaw", "lapseRawPerBlock",
        "exposureCoolingRaw", "exposureDryingRaw", "flowMoistureGainRaw",
        "minimumTemperatureRaw", "maximumTemperatureRaw", "minimumMoistureRaw", "maximumMoistureRaw"
      ],
      "properties": {
        "kernelVersion": { "const": "climate-final-fixed-v1" },
        "baseTemperatureRaw": { "type": "integer", "minimum": -1000, "maximum": 1000 },
        "latitudeCoolingRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "lapseRawPerBlock": { "type": "integer", "minimum": 0, "maximum": 32 },
        "exposureCoolingRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "exposureDryingRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "flowMoistureGainRaw": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "minimumTemperatureRaw": { "const": -1000 },
        "maximumTemperatureRaw": { "const": 1000 },
        "minimumMoistureRaw": { "const": 0 },
        "maximumMoistureRaw": { "const": 1000 }
      }
    },
    "hydrologyHandoff": {
      "type": "object", "additionalProperties": false,
      "required": [
        "bindingVersion", "sourcePriorKind", "sourceHydrologyPlanChecksum",
        "sourceHydrologyPriorChecksum", "sourceConstantRunoffMillionths",
        "replacementClimatePriorChecksum", "sourceGeneratorVersion", "targetGeneratorVersion",
        "transitionContractVersion", "transitionMode"
      ],
      "properties": {
        "bindingVersion": { "const": 1 },
        "sourcePriorKind": { "const": "CONSTANT_RUNOFF_PRIOR" },
        "sourceHydrologyPlanChecksum": { "$ref": "#/$defs/checksum" },
        "sourceHydrologyPriorChecksum": { "$ref": "#/$defs/checksum" },
        "sourceConstantRunoffMillionths": { "const": 1000000 },
        "replacementClimatePriorChecksum": { "$ref": "#/$defs/checksum" },
        "sourceGeneratorVersion": { "const": "hydrology-priority-flood-v1" },
        "targetGeneratorVersion": { "const": "hydrology-priority-flood-climate-prior-v1" },
        "transitionContractVersion": { "const": "hydrology-climate-prior-binding-v1" },
        "transitionMode": { "const": "EXPLICIT_VERSION_TRANSITION" }
      }
    },
    "fieldBinding": {
      "type": "object", "additionalProperties": false,
      "required": [
        "fieldId", "semantic", "valueType", "phase", "ownerModuleId",
        "ownership", "sampling", "scaleMillionths"
      ],
      "properties": {
        "fieldId": { "$ref": "#/$defs/qualified" },
        "semantic": {
          "enum": ["PRIOR_PRECIPITATION", "PRIOR_RUNOFF", "FINAL_TEMPERATURE", "FINAL_MOISTURE"]
        },
        "valueType": { "enum": ["U16", "I16"] },
        "phase": { "enum": ["PRIOR", "FINAL"] },
        "ownerModuleId": { "$ref": "#/$defs/qualified" },
        "ownership": { "const": "SINGLE_OWNER" },
        "sampling": { "const": "BILINEAR_FIXED" },
        "scaleMillionths": { "const": 1000 }
      }
    },
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": [
        "budgetVersion", "maximumFields", "globalCellCount", "coarseCellCount",
        "estimatedCpuWorkUnits", "estimatedRetainedBytes", "maximumWindowSize",
        "maximumWorkingBytes", "maximumCanonicalBytes"
      ],
      "properties": {
        "budgetVersion": { "const": "climate-field-budget-v1" },
        "maximumFields": { "const": 4 },
        "globalCellCount": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "coarseCellCount": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "estimatedCpuWorkUnits": { "type": "integer", "minimum": 1, "maximum": 16000000 },
        "estimatedRetainedBytes": { "type": "integer", "minimum": 1, "maximum": 4194304 },
        "maximumWindowSize": { "type": "integer", "minimum": 1, "maximum": 256 },
        "maximumWorkingBytes": { "type": "integer", "minimum": 1, "maximum": 8388608 },
        "maximumCanonicalBytes": { "type": "integer", "minimum": 1, "maximum": 131072 }
      }
    }
  }
}
